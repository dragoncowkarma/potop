<?xml version="1.0" encoding="UTF-8"?>
<ProjectContext>
  <Meta>
    <Purpose>POTOP (Project Over-The-Top Power) is a 3D roguelite turret defense game focusing on wave-based combat and strategic progression.</Purpose>
    <UnityVersion>6000.0.73f1</UnityVersion>
    <RenderPipeline>Universal Render Pipeline (URP)</RenderPipeline>
    <Architecture>Singleton-based Global State Management transitioning to Event-Driven Architecture (Event Broker).</Architecture>
  </Meta>

  <Dependencies>
    <Package name="com.unity.inputsystem">New Input System for player controls.</Package>
    <Package name="com.unity.render-pipelines.universal">URP for modern rendering.</Package>
    <Package name="com.unity.ugui">Legacy UI components used in current HUD.</Package>
    <Package name="com.coplaydev.unity-mcp">Model Context Protocol integration.</Package>
  </Dependencies>

  <CoreScenes>
    <Scene path="Assets/Scenes/Start.unity">Main menu and lobby for turret selection.</Scene>
    <Scene path="Assets/Scenes/MainScene.unity">Primary Wave Mode gameplay scene.</Scene>
  </CoreScenes>

  <CoreScripts>
    <Module name="GameManager" type="Manager">
      <Path>Assets/Scripts/Core/GameManager.cs</Path>
      <Responsibility>Singleton managing global state (HP, Score, GameState).</Responsibility>
    </Module>
    <Module name="GameHUD" type="Controller">
      <Path>Assets/Scripts/Core/GameHUD.cs</Path>
      <Responsibility>UI controller for real-time gameplay feedback.</Responsibility>
    </Module>
    <File Path="docs/gdd/01_overview.md" Description="Project high-level overview & vision"/>
    <File Path="docs/gdd/02_target_audience.md" Description="Target players & market analysis"/>
    <File Path="docs/gdd/03_core_value_and_usp.md" Description="USP & core gameplay satisfaction"/>
    <File Path="docs/gdd/04_key_features.md" Description="Index: Key systems & features"/>
    <File Path="docs/gdd/04_1_core_gameplay.md" Description="Controls & Win/Loss conditions"/>
    <File Path="docs/gdd/04_2_turrets_enemies.md" Description="Turret classes & Enemy types"/>
    <File Path="docs/gdd/04_3_abilities_evolution.md" Description="Level-up stats & Weapon evolution"/>
    <File Path="docs/gdd/04_4_tactical_skills.md" Description="Active skills & Energy system"/>
    <File Path="docs/gdd/04_5_items_exp.md" Description="EXP gems & Field drop items"/>
    <File Path="docs/gdd/04_6_combo_fever.md" Description="Combo multipliers & Fever effects"/>
    <File Path="docs/gdd/04_7_balance_stats.md" Description="Detailed balance tables & stats"/>
    <File Path="docs/gdd/04_8_wave_timeline.md" Description="15-min Wave timeline & Boss phase"/>
    <File Path="docs/gdd/04_9_implementation_details.md" Description="Architecture: Event Broker & Pooling"/>
    <File Path="docs/gdd/05_art_sound.md" Description="Cyberpunk/Neon aesthetic & soundscape"/>
    <Module name="TurretShooter" type="Controller">
      <Path>Assets/Scripts/TurretShooter.cs</Path>
      <Responsibility>Player input handling for 360-degree combat.</Responsibility>
    </Module>
    <Module name="EnemySpawner" type="Utility">
      <Path>Assets/Scripts/EnemySpawner.cs</Path>
      <Responsibility>Wave-based enemy generation logic.</Responsibility>
    </Module>
    <!-- Note: Survival Mode (StageMain, Obstacle) is deprecated and being removed from the roadmap. -->
  </CoreScripts>

  <DataFlowAndState>
    <Description>Global state is centralized in GameManager. Future expansion includes a dedicated EventBroker for decoupled communication and ScriptableObject-based data management for wave and weapon balancing.</Description>
  </DataFlowAndState>

  <StrictConventions>
    <Rule>Focus exclusively on Wave Mode (Turret Defense) development.</Rule>
    <Rule>Rely on GameManager.Instance for global state; transition to EventBroker for notifications.</Rule>
    <Rule>Strictly avoid GameObject.Find(); use inspector refs or singletons.</Rule>
    <Rule>Prefer Unity UI Toolkit for new UI screens.</Rule>
  </StrictConventions>
</ProjectContext>
